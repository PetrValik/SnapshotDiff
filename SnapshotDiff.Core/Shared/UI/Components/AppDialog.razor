@namespace SnapshotDiff.Shared.UI.Components

@if (IsOpen)
{
    <div class="fixed inset-0 z-50 flex items-center justify-center">
        <!-- Backdrop -->
        <div class="absolute inset-0 bg-black/60" @onclick="OnBackdropClick"></div>

        <!-- Dialog -->
        <div class="relative card p-6 w-full max-w-md mx-4 shadow-2xl z-10">
            @if (!string.IsNullOrEmpty(Title))
            {
                <h3 class="text-base font-semibold mb-2" style="color: var(--text)">@Title</h3>
            }

            <div class="text-sm mb-6" style="color: var(--text-secondary)">
                @ChildContent
            </div>

            <div class="flex justify-end gap-2">
                @if (Footer is not null)
                {
                    @Footer
                }
                else
                {
                    <AppButton Variant="ghost" OnClick="CloseAsync">@CancelText</AppButton>
                    <AppButton Variant="@ConfirmVariant" OnClick="ConfirmAsync">@ConfirmText</AppButton>
                }
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public EventCallback<bool> IsOpenChanged { get; set; }
    [Parameter] public string Title { get; set; } = "";
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public RenderFragment? Footer { get; set; }
    [Parameter] public string ConfirmText { get; set; } = "Confirm";
    [Parameter] public string CancelText { get; set; } = "Cancel";
    [Parameter] public string ConfirmVariant { get; set; } = "primary";
    [Parameter] public EventCallback OnConfirm { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }
    [Parameter] public bool CloseOnBackdrop { get; set; } = true;

    private async Task CloseAsync()
    {
        await IsOpenChanged.InvokeAsync(false);
        await OnCancel.InvokeAsync();
    }

    private async Task ConfirmAsync()
    {
        await IsOpenChanged.InvokeAsync(false);
        await OnConfirm.InvokeAsync();
    }

    private async Task OnBackdropClick()
    {
        if (CloseOnBackdrop) await CloseAsync();
    }
}
