@using SnapshotDiff.Components.Shared
@using SnapshotDiff.Infrastructure.Theme
@using SnapshotDiff.Infrastructure.Localization
@inject IThemeService ThemeService
@inject IStringLocalizer<LayoutResources> Loc
@inject IJSRuntime JS
@inherits LayoutComponentBase

<div class="flex h-screen overflow-hidden" style="background: var(--bg-main)">
    <!-- Sidebar -->
    <nav class="flex flex-col w-52 shrink-0 border-r" style="background: var(--bg-topbar); border-color: var(--border)">
        <!-- Logo -->
        <div class="flex items-center gap-2 px-4 py-4 border-b" style="border-color: var(--border)">
            <span style="color: var(--accent)" class="text-lg font-bold tracking-tight flex-1">SnapshotDiff</span>
            <CultureSelector />
        </div>

        <!-- Nav links -->
        <div class="flex-1 px-2 py-3 space-y-1 overflow-y-auto">
            <NavLink class="nav-link" href="/" Match="NavLinkMatch.All">
                <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                </svg>
                <span>@Loc["Nav_Scan"]</span>
            </NavLink>
            <NavLink class="nav-link" href="/trash">
                <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                </svg>
                <span>@Loc["Nav_Trash"]</span>
            </NavLink>
            <NavLink class="nav-link" href="/exclusions">
                <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                          d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636" />
                </svg>
                <span>@Loc["Nav_Exclusions"]</span>
            </NavLink>
            <NavLink class="nav-link" href="/settings">
                <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
                <span>@Loc["Nav_Settings"]</span>
            </NavLink>
        </div>

        <!-- Bottom: version -->
        <div class="px-4 flex items-center h-10 border-t text-xs" style="border-color: var(--border); color: var(--text-muted)">
            @Loc["Nav_AppVersion"]
        </div>
    </nav>

    <!-- Main content -->
    <main class="flex-1 overflow-auto">
        @Body
    </main>
</div>

<ToastContainer />
<ReconnectModal />

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try { await ThemeService.ApplyAsync(); }
            catch (Exception e) when (e is JSDisconnectedException or ObjectDisposedException) { }
            try { await JS.InvokeVoidAsync("revealPage"); }
            catch (Exception e) when (e is JSDisconnectedException or ObjectDisposedException) { }
        }
    }
}
