@namespace SnapshotDiff.Components.Shared

@if (IsVisible)
{
    <div class="fixed inset-0 z-50 flex items-center justify-center bg-black/60 backdrop-blur-sm p-4" @onclick="HandleBackdropClick">
        <div class="bg-surface border border-border rounded-xl shadow-2xl w-full max-w-md p-6 space-y-4" @onclick:stopPropagation>

            @if (IsSystemProtected)
            {
                <!-- System-protected: strict warning -->
                <div class="flex items-start gap-3 p-4 rounded-lg bg-red-500/10 border border-red-500/40">
                    <svg class="w-6 h-6 text-red-400 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                    </svg>
                    <div>
                        <p class="font-semibold text-red-400">@Loc["Dialog_SystemProtected_Title"]</p>
                        <p class="text-sm text-muted mt-1">@Loc["Dialog_SystemProtected_Warning"]</p>
                    </div>
                </div>
            }

            <div>
                <h2 class="text-lg font-semibold">@Loc["Dialog_Delete_Title"]</h2>
                <p class="text-sm text-muted mt-1">
                    @Loc["Dialog_Delete_Prompt"] <strong class="text-content break-all">@FileName</strong>
                </p>
            </div>

            @if (IsSystemProtected)
            {
                <div class="space-y-2">
                    <p class="text-sm text-muted">
                        @string.Format(Loc["Dialog_SystemProtected_TypePrompt"], ConfirmWord)
                    </p>
                    <input class="input w-full font-mono"
                           placeholder="@ConfirmWord"
                           @bind="_typedWord"
                           @bind:event="oninput"
                           @onkeydown="HandleKeyDown" />
                </div>
            }

            <div class="flex justify-end gap-3 pt-2">
                <button class="btn btn-ghost" @onclick="Cancel">@Loc["Dialog_Cancel"]</button>
                <button class="btn @(IsSystemProtected ? "bg-red-600 hover:bg-red-700 text-white" : "btn-danger")"
                        disabled="@(!CanConfirm)"
                        @onclick="Confirm">
                    @Loc["Dialog_Delete_Confirm"]
                </button>
            </div>
        </div>
    </div>
}
