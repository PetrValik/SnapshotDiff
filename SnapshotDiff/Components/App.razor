<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <link rel="stylesheet" href="_content/SnapshotDiff.App/app.css" />
    <link rel="icon" type="image/png" href="_content/SnapshotDiff.App/favicon.png" />
    <HeadOutlet />
    <script>
        // Apply saved theme before first render to prevent flash
        (function () {
            try {
                var s = localStorage.getItem('snapshotdiff-theme');
                if (s) {
                    var obj = JSON.parse(s);
                    if (obj && obj.Appearance && obj.Appearance.Theme === 'light')
                        document.documentElement.classList.add('light');
                }
            } catch (e) { }
        })();
    </script>
</head>
<body>
    <Routes />
    <script src="_framework/blazor.web.js"></script>
    <script>function revealPage() { document.body.style.opacity = '1'; }</script>
</body>
</html>
